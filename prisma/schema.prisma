generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  password   String
  phone      String?
  role       UserRole   @default(CLIENT)
  isVerified Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  cart       Cart?
  driver     Driver?
  orders     Order[]
  otpTokens  OtpToken[]
  notifications Notification[]
}

model OtpToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Restaurant {
  id        Int        @id @default(autoincrement())
  name      String
  address   String
  phone     String?
  imageUrl  String?
  latitude  Float?
  longitude Float?
  isOpen    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  carts     Cart[]
  menuItems MenuItem[]
  orders    Order[]

  @@index([isOpen])
}

model MenuItem {
  id           Int         @id @default(autoincrement())
  restaurantId Int
  name         String
  description  String?
  price        Float
  imageUrl     String?
  isAvailable  Boolean     @default(true)
  category     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  cartItems    CartItem[]
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@index([restaurantId])
  @@index([isAvailable])
}

model Cart {
  id           Int         @id @default(autoincrement())
  userId       Int         @unique
  restaurantId Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        CartItem[]

  @@index([userId])
  @@index([restaurantId], map: "Cart_restaurantId_fkey")
}

model CartItem {
  id         Int      @id @default(autoincrement())
  cartId     Int
  menuItemId Int
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([cartId, menuItemId])
  @@index([cartId])
  @@index([menuItemId], map: "CartItem_menuItemId_fkey")
}

model Driver {
  id          Int        @id @default(autoincrement())
  userId      Int        @unique
  licenseNo   String     @unique
  isAvailable Boolean    @default(true)
  deliveries  Delivery[]
  user        User       @relation(fields: [userId], references: [id])
  vehicle     Vehicle?
}

model Vehicle {
  id          Int         @id @default(autoincrement())
  driverId    Int         @unique
  type        VehicleType
  plateNumber String      @unique
  color       String?
  year        Int?
  driver      Driver      @relation(fields: [driverId], references: [id])
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  restaurantId    Int
  status          OrderStatus @default(PENDING)
  pickupAddress   String
  deliveryAddress String
  pickupLat       Float?
  pickupLng       Float?
  deliveryLat     Float?
  deliveryLng     Float?
  totalPrice      Float
  note            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  delivery        Delivery?
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  payment         Payment?

  @@index([userId])
  @@index([status])
  @@index([restaurantId])
}

model OrderItem {
  id         Int       @id @default(autoincrement())
  orderId    Int
  menuItemId Int?
  name       String
  quantity   Int
  unitPrice  Float
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId], map: "OrderItem_menuItemId_fkey")
}

model Delivery {
  id        Int            @id @default(autoincrement())
  orderId   Int            @unique
  driverId  Int
  startedAt DateTime?
  endedAt   DateTime?
  status    DeliveryStatus @default(ASSIGNED)
  driver    Driver         @relation(fields: [driverId], references: [id])
  order     Order          @relation(fields: [orderId], references: [id])
  tracking  Tracking[]

  @@index([driverId])
}

model Notification {
  id          Int  @id @default(autoincrement())
  userId      Int 
  title       String
  message     String
  type        NotificationType
  status      NotificationStatus
  read        Boolean         @default(false)
  data        Json?
  sentAt      DateTime?   
  readAt      DateTime?
  createdAt   DateTime?      @default(now())
  updatedAt   DateTime?      @updatedAt

  user        User @relation(fields: [userId], references : [id], onDelete : Cascade)
  @@index([userId])
  @@index([status])
  @@index([read])
  @@map("notification")
}

model Tracking {
  id         Int      @id @default(autoincrement())
  deliveryId Int
  latitude   Float
  longitude  Float
  accuracy   Float?
  createdAt  DateTime @default(now())
  delivery   Delivery @relation(fields: [deliveryId], references: [id])

  @@index([deliveryId, createdAt])
}

model Payment {
  id      Int           @id @default(autoincrement())
  orderId Int           @unique
  amount  Float
  method  PaymentMethod
  status  PaymentStatus @default(PENDING)
  paidAt  DateTime?
  order   Order         @relation(fields: [orderId], references: [id])
}

enum UserRole {
  ADMIN
  CLIENT
  DRIVER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELED
}

enum DeliveryStatus {
  ASSIGNED
  EN_ROUTE
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum VehicleType {
  BIKE
  MOTORBIKE
  CAR
  TRUCK
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
enum NotificationType {
 ORDER_CREATED
 ORDER_ACCEPTED
 ORDER_PREPARING
 ORDER_READY
 ORDER_DELIVERING
 ORDER_DELIVERED

 PAYMENT_SUCCESS
 PAYMENT_FAILED

 DRIVER_ASSIGNED
 PROMOTION
 SYSTEM
}
enum NotificationStatus{
  PENDING
  SENT 
  FAILED
}
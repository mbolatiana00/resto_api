generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model delivery {
  id        Int       @id @default(autoincrement())
  orderId   Int       @unique(map: "Delivery_orderId_key")
  driverId  Int
  startedAt DateTime?
  endedAt   DateTime?

  // ✅ Relations
  order    order      @relation(fields: [orderId], references: [id])
  driver   driver     @relation(fields: [driverId], references: [id])
  tracking tracking[]

  @@index([driverId], map: "Delivery_driverId_fkey")
}

model driver {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique(map: "Driver_userId_key")
  licenseNo   String
  isAvailable Boolean @default(true)

  // ✅ Relations
  user      user       @relation(fields: [userId], references: [id])
  vehicle   vehicle?
  delivery  delivery[]
}

model order {
  id              Int          @id @default(autoincrement())
  userId          Int
  status          order_status @default(PENDING)
  pickupAddress   String
  deliveryAddress String
  price           Float
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // ✅ Relations
  user     user      @relation(fields: [userId], references: [id])
  delivery delivery?
  payment  payment?

  @@index([userId], map: "Order_userId_fkey")
}

model payment {
  id      Int            @id @default(autoincrement())
  orderId Int            @unique(map: "Payment_orderId_key")
  amount  Float
  method  String
  status  payment_status @default(PENDING)
  paidAt  DateTime?

  // ✅ Relation
  order order @relation(fields: [orderId], references: [id])
}

model tracking {
  id         Int      @id @default(autoincrement())
  deliveryId Int
  latitude   Float
  longitude  Float
  createdAt  DateTime @default(now())

  // ✅ Relation
  delivery delivery @relation(fields: [deliveryId], references: [id])

  @@index([deliveryId], map: "Tracking_deliveryId_fkey")
}

model user {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique(map: "User_email_key")
  password  String
  createdAt DateTime  @default(now())
  phone     String?
  role      user_role @default(CLIENT)
  updatedAt DateTime  @updatedAt

  // ✅ Relations
  order  order[]
  driver driver?
}

model vehicle {
  id          Int          @id @default(autoincrement())
  driverId    Int          @unique(map: "Vehicle_driverId_key")
  type        vehicle_type
  plateNumber String
  color       String?

  // ✅ Relation
  driver driver @relation(fields: [driverId], references: [id])
}

enum order_status {
  PENDING
  CONFIRMED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELED
}

enum vehicle_type {
  BIKE
  MOTORBIKE
  CAR
  TRUCK
}

enum payment_status {
  PENDING
  PAID
  FAILED
}

enum user_role {
  ADMIN
  CLIENT
  DRIVER
}
